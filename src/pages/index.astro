<script is:inline>
	// Detectamos el idioma del navegador
	const lang = window.navigator.language.split('-')[0] === 'en' ? 'en' : 'es';
	
	// Redirigimos a la ruta generada por [lang].astro
	// Usamos replace para que el usuario no pueda "volver" a la página de carga
	window.location.replace(`/${lang}/`);
</script>

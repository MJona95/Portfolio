<script is:inline>
	// Detectamos el idioma del navegador
	const lang = window.navigator.language.split('-')[0] === 'en' ? 'en' : 'es';
	
	// Obtenemos la ruta actual para manejar correctamente el despliegue en subcarpetas
	const pathname = window.location.pathname;
	const baseUrl = pathname.endsWith('/') ? pathname : pathname + '/';

	window.location.replace(`${baseUrl}${lang}/`);
</script>

---
// src/pages/index.astro
---

<script is:inline>
  // Detectar el idioma del navegador
  const lang = window.navigator.language.split('-')[0] === 'en' ? 'en' : 'es';
  
  // Obtener la ruta actual (esto ya maneja /Portfolio/ automáticamente)
  const pathname = window.location.pathname;
  
  // Si la ruta termina con /Portfolio/ o /Portfolio, redirigir correctamente
  let baseUrl = pathname;
  if (!pathname.endsWith('/')) {
    baseUrl = pathname + '/';
  }
  
  // Redirigir al idioma correspondiente
  window.location.replace(`${baseUrl}${lang}/`);
</script>

<html>
  <body>
    <p>Redirigiendo...</p>
  </body>
</html>
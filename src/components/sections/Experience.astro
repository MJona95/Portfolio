---
import Section from "@/components/Section.astro";
import { work } from "@cv"
import { getLangFromParams, useTranslations } from '@/components/i18n';

const { lang: paramLang } = Astro.params;
const lang = getLangFromParams(paramLang);
const t = useTranslations(lang);
---
<Section title={t({ es: "Experiencia Laboral", en: "Work Experience" })}>
    <ul>
        {work.map(({name, startDate, endDate, position, summary}) => {
            const startYear = new Date(startDate).getFullYear()
            const endYear = 
                endDate !== null && endDate !== "null" 
                ? new Date(endDate).getFullYear() 
                : t({ es: "Actualidad", en: "Present" })
            
            const years = `${startYear} - ${endYear}`

            return(
                <li>
                    <article>
                        <header>
                            <div>
                                <h3>{name}</h3>
                                <h4>{t(position)}</h4>
                            </div>
                            <time>{years}</time>
                        </header>
                        <footer>
                            <p>{t(summary)}</p>
                        </footer>
                    </article>
                </li>
            )
        })}
    </ul>
</Section>

<style>
    ul {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }

    article h3 {
        font-weight: 500;
        color: #111;
    }

    article h4 {
        font-weight: 400;
        color: #222;
    }

    header {
        display: flex;
        justify-content: space-between;
        align-items: start;
        margin-bottom: 4px;
    }

    time {
        color: #555;
        font-size: 0.85rem;
    }
</style>
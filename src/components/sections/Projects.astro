---
import Section from "../Section.astro";
import { projects } from "@cv"

const lang = (Astro.params.lang || "es") as "es" | "en";

const t = (value: any) => {
  if (value && typeof value === "object" && value[lang]) {
    return value[lang] as string;
  }
  return value;
};
---

<Section title={t({ es: "Proyectos", en: "Projects" })}>
    <ul>
        {
            projects.map(({url, description, highlights = [], name, isActive}) => {
                return(
                    <li>
                        <article>
                            <header>
                                <h3>
                                    <a href={url} title={t({
                                        es: `Ver el repositorio del proyecto ${name}`,
                                        en: `View the project repository ${name}`
                                    })}>
                                        {name}
                                    </a>
                                    {
                                        isActive && <span>&bull;</span>
                                    }
                                </h3>
                                <p>{t(description)}</p>
                            </header>
                            <footer>
                                    {
                                        highlights.map(highlight => {
                                            return(
                                                <span>{t(highlight)}</span>
                                            )
                                        })
                                    }
                            </footer>
                        </article>
                    </li>
                )
            })
        }
    </ul>
</Section>

<style>
    ul {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
    }

    article {
        border: 1px solid #f2f2f2;
        border-radius: 8px;
        gap: 16px;
        display: flex;
        flex-direction: column;
        padding: 16px;
        height: 100%;
    }

    article header {
        flex: 1;
    }

    article h3 {
        margin-bottom: 4px;
    }

    article h3 span {
        color: rgb(0, 188, 47);
    }

    article a {
        color: #111;
    }

    article a:hover {
        text-decoration: underline;
    }

    article p {
        font-size: 0.85rem;
        line-height: 1.2rem;
        padding-bottom: 4px;
    }

    footer {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        font-size: 0.6rem;
    }

    footer span {
        border-radius: 6px;
        background: #eee;
        color: #444;
        font-size: 0.8rem;
        font-weight: 500;
        padding: 0.2rem 0.6rem;
        display: inline;
    }

</style>
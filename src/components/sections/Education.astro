---
import Section from "@/components/Section.astro";
import { education } from "@cv";

const lang = (Astro.params.lang || "es") as "es" | "en";

const t = (value: any) => {
  if (value && typeof value === "object" && value[lang]) {
    return value[lang] as string;
  }
  return value;
};
---
<Section title={t({ es: "Educación", en: "Education" })}> 
    <ul>
        {
            education.map(({institution, area, startDate, endDate}) => {
                const startYear = new Date(startDate).getFullYear();
                const endYear = 
                    endDate !== null && endDate !== "null" 
                    ? new Date(endDate).getFullYear() 
                    : t({ es: "Actualidad", en: "Present" })
                const years = `${startYear} - ${endYear}`

                return(
                <li>
                    <article>
                        <header>
                            <h3>{institution}</h3>
                            <time>{years}</time>
                        </header>
                    </article>
                    <h4>{t(area)}</h4>
                </li>
                )
            })
        }
        
    </ul>
</Section>

<style>
    ul {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }

    article h3 {
        font-weight: 600;
        color: #111;
    }

    article h4 {
        font-weight: 200;
        color: #222;
    }

    header {
        display: flex;
        justify-content: space-between;
        align-items: start;
        margin-bottom: 4px;
    }

    time {
        color: #555;
        font-size: 0.85rem;
    }
</style>
---
import Section from "@/components/Section.astro";
import { basics } from "@cv"
import { getLangFromParams, useTranslations } from '@/components/i18n';

const { lang: paramLang } = Astro.params;
const lang = getLangFromParams(paramLang);
const t = useTranslations(lang);

const { summary } = basics

---

<Section title={t({ es: "Sobre mí", en: "About me" })}>
    <p>
        {t(summary)}
    </p>
</Section>
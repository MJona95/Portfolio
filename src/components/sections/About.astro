---
import Section from "@/components/Section.astro";
import { basics } from "@cv"

const { lang: paramLang } = Astro.params;
const browserLang = Astro.request.headers.get("accept-language")?.slice(0, 2);
const lang = (paramLang || (browserLang === "en" ? "en" : "es")) as "es" | "en";

const t = (value: any) => {
  if (value && typeof value === "object" && value[lang]) {
    return value[lang] as string;
  }
  return value;
};

const { summary } = basics

---

<Section title={t({ es: "Sobre mí", en: "About me" })}>
    <p>
        {t(summary)}
    </p>
</Section>
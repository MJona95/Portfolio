---
import { basics } from "@cv"

const lang = (Astro.params.lang || "es") as "es" | "en";

const t = (value: any) => {
  if (value && typeof value === "object" && value[lang]) {
    return value[lang] as string;
  }
  return value;
};

const { profiles } = basics
---
<footer class="no-print">
    {t({ es: "Pulsa", en: "Press" })} <kbd>Ctrl</kbd> + <kbd>k</kbd> {t({ es: "para abrir la paleta de comandos.", en: "to open the command palette." })}
</footer>

<ninja-keys
    placeholder={t({ es: "Buscar comando", en: "Search command" })} 
    hideBreadcrumbs
    data-print={t({ es: "Imprimir", en: "Print" })}
    data-actions={t({ es: "Acciones", en: "Actions" })}
></ninja-keys>

<script>
    import "ninja-keys"

    const ninja = document.querySelector("ninja-keys") as any

    if(ninja != null) {
        const { print, actions } = ninja.dataset

        ninja.data = [
        {
      id: 'Print',
      title: print,
      hotkey: 'ctrl+P',
      section: actions,
      handler: () => {
        window.print()
      },
    },
        ]
    }

</script>

<style>

    @keyframes fadeIn {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    @media print {
        ninja-keys {
            display: none !important;
        }
    }

    footer {
        background: #fdfdfd;
        border-top: 1px solid #eee;
        position: fixed;
        bottom: 0;
        width: 100%;
        padding-block: 8px;
        text-align: center;
        
        view-timeline-name: --revealing;
        view-timeline-axis: block;

        animation: linear 0.3s fadeIn;
        animation-timeline: --revealing;
        animation-range: entry 100% cover 10%;
    }
</style>